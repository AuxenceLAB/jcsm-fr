# jcsm.cloud — Interface de gestion interne JCSM
upstream jcsm_cloud_backend {
    server localhost:3001 max_fails=3 fail_timeout=30s;
    keepalive 16;
}

# Redirect www → non-www (HTTPS)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name www.jcsm.cloud;

    ssl_certificate /etc/letsencrypt/live/jcsm.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/jcsm.cloud/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://jcsm.cloud$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name jcsm.cloud;

    ssl_certificate /etc/letsencrypt/live/jcsm.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/jcsm.cloud/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers (sans CSP - geree par le middleware Next.js)
    include /etc/nginx/snippets/security-noCSP.conf;

    client_max_body_size 20M;

    # Next.js static files
    location /_next/static {
        alias /var/www/jcsm-cloud/.next/static;
        expires 365d;
        access_log off;
        log_not_found off;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        try_files $uri =404;
    }

    # Health check
    location /api/health {
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    # Login — strict rate limiting
    location /api/auth/login {
        limit_req zone=jcsm_login burst=3 nodelay;
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # AI/Agent endpoints — timeout long + streaming support
    location ~ ^/api/(agents|ai)/ {
        limit_req zone=jcsm_api burst=50 nodelay;
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
        chunked_transfer_encoding on;
    }

    # API — rate limiting
    location /api/ {
        limit_req zone=jcsm_api burst=50 nodelay;
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Webhook (n8n incoming) — rate limited to prevent abuse
    location /api/webhook {
        limit_req zone=jcsm_api burst=20 nodelay;
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Default — Next.js app (with rate limiting)
    location / {
        limit_req zone=app burst=30 nodelay;
        proxy_pass http://jcsm_cloud_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Block hidden files
    location ~ /\. {
        deny all;
        access_log off;
    }

    access_log /var/log/nginx/jcsm-cloud.access.log;
    error_log /var/log/nginx/jcsm-cloud.error.log;
}

server {
    listen 80;
    listen [::]:80;
    server_name jcsm.cloud www.jcsm.cloud;
    return 301 https://jcsm.cloud$request_uri;
}
